{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "agent": {
    "general": { "disable": true },
    "explore": { "disable": true }
  },
  "provider": {
    "tasknode": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://endpoint.tasknode.app/v1"
      },
      "models": {
        "glm-5.1:cloud": {
          "name": "GLM 5.1",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "glm-5.2:cloud": {
          "name": "GLM 5.2",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "variants": {
            "low": { "reasoningEffort": "low" },
            "medium": { "reasoningEffort": "medium" },
            "high": { "reasoningEffort": "high" },
            "max": { "reasoningEffort": "max" }
          }
        },
        "minimax-m3:cloud": {
          "name": "MiniMax M3",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "qwen3.5:cloud": {
          "name": "Qwen 3.5",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "qwen3.5:397b-cloud": {
          "name": "Qwen 3.5 397B",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "kimi-k2.6": {
          "name": "Kimi K2.6",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "kimi-k2.7": {
          "name": "Kimi K2.7",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    },
    "zen": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.zenllm.org/v1"
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT-5.5",
          "cost": {
            "input": 5,
            "output": 30,
            "cache_read": 0.5
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "anthropic/claude-opus-4.8": {
          "name": "Claude Opus 4.8",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "zhipu/glm-5.1": {
          "name": "GLM 5.1"
        }
      }
    }
  }
}